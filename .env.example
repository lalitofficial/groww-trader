# Option A: use a previously generated access token directly.
GROWW_ACCESS_TOKEN=

# Option B: daily API key and secret approval flow.
GROWW_API_KEY=
GROWW_API_SECRET=

# Option C: TOTP flow.
GROWW_TOTP_TOKEN=
GROWW_TOTP_SECRET=

# Defaults for CLI market-data commands.
GROWW_DEFAULT_EXCHANGE=NSE
GROWW_DEFAULT_SEGMENT=CASH

# Dashboard runtime.
GROWW_TRADER_DB=data/groww_trader.sqlite3
GROWW_API_HOST=127.0.0.1
GROWW_API_PORT=8000
GROWW_FRONTEND_PORT=3000
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000

# Account + risk defaults.
SWING_ACCOUNT_CAPITAL=500000
SWING_RISK_PER_TRADE_PCT=1.0
SWING_BENCHMARK_SYMBOL=NSE_NIFTY
SWING_SCAN_SYMBOLS=RELIANCE,TCS,HDFCBANK,INFY,ICICIBANK,SBIN,LT,AXISBANK,ITC,BHARTIARTL

# Intraday-specific risk knobs.
INTRADAY_LEVERAGE=5
INTRADAY_MAX_DAILY_LOSS_PCT=3.0
INTRADAY_MAX_POSITION_PCT=20.0
INTRADAY_ATR_STOP_MULT=1.5
INTRADAY_DEFAULT_TIMEFRAME=15

# Paper trading cost model.
PAPER_CAPITAL=500000
PAPER_BROKERAGE_PER_TRADE=20
PAPER_STT_PCT_INTRADAY=0.025
PAPER_STT_PCT_DELIVERY=0.1
PAPER_SLIPPAGE_BPS=5

# Optional sector / index breadth gauges (override NIFTY 50 universe + sector indices).
# NIFTY50_SYMBOLS=
# SECTOR_INDEX_SYMBOLS=NSE_BANKNIFTY,NSE_NIFTYIT,NSE_NIFTYAUTO

# Public market data routing. Groww market-data fallback is off by default.
MARKET_DATA_PROVIDER_ORDER=yahoo,stooq
MARKET_DATA_ALLOW_GROWW_FALLBACK=false
MARKET_DATA_DAILY_TTL_MIN=360
MARKET_DATA_INTRADAY_TTL_MIN=5
ALPHA_VANTAGE_API_KEY=

# Telegram alert delivery (optional). Create a bot via @BotFather and grab your numeric chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Azure OpenAI GPT-5.4 analyst mode.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
